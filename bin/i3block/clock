#!/bin/sh

clock=$(date '+%I')

case "$clock" in
	"00") icon="юОБ " ;;
	"01") icon="юОВ " ;;
	"02") icon="юОГ " ;;
	"03") icon="юОД " ;;
	"04") icon="юОЕ " ;;
	"05") icon="юОЖ " ;;
	"06") icon="юОЗ " ;;
	"07") icon="юОИ " ;;
	"08") icon="юОЙ " ;;
	"09") icon="юОК " ;;
	"10") icon="юОЛ " ;;
	"11") icon="юОМ " ;;
	"12") icon="юОБ " ;;
esac

case $BLOCK_BUTTON in
	1) notify-send "This Month" "$(cal --color=always | sed "s/..7m/<b><span color=\"red\">/;s/..27m/<\/span><\/b>/")" && notify-send "Appointments" "$(calcurse -d3)" ;;
	2) setsid -f "$TERMINAL" -e calcurse ;;
	3) notify-send "ЁЯУЕ Time/date module" "\- Left click to show upcoming appointments for the next three days via \`calcurse -d3\` and show the month via \`cal\`
- Middle click opens calcurse if installed" ;;
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

date "+%a, %d.%b %Y $icon%H:%M"

