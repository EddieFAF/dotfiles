# Resize Right
super + r : Right
    bspc node -z right 50 0 || bspc node -z left 50 0

# Resize Left
super + r : Left
    Left bspc node -z left -50 0 || bspc node -z right -50 0

# Resize Up
super + r : Up
    Up bspc node -z top 0 -50 || bspc node -z bottom 0 -50

# Resize Down
super + r : Down
    Down bspc node -z bottom 0 50 || bspc node -z top 0 50

# move a floating window
#super + {Left,Down,Up,Right}
#	bspc node -v {-20 0,0 20,0 -20,20 0}

# focus mode: float, resize and center
super + ctrl + f
    bspc rule -a \* --one-shot state=floating rectangle=920x80+50+40; \
    bspc node -t floating

# sticky mode: window on top of all desktops
super + ctrl + s
    bspc node -t floating; \
	bspc node -g sticky

