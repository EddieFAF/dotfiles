# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $mod Mod4

set_from_resource $fg i3wm.foreground #f0f0f0
set_from_resource $bg i3wm.background #101010
set_from_resource $col0 i3wm.color0 #000000
set_from_resource $col1 i3wm.color1 #f00000
set_from_resource $col2 i3wm.color2 #f000f0
set_from_resource $col3 i3wm.color3 #202020
set_from_resource $col4 i3wm.color4 #202020
set_from_resource $col5 i3wm.color5 #404040
set_from_resource $col6 i3wm.color6 #202020
set_from_resource $col7 i3wm.color7 #202020
set_from_resource $col8 i3wm.color8 #202020
set_from_resource $col9 i3wm.color9 #202020
set_from_resource $col10 i3wm.color10 #202020
set_from_resource $col11 i3wm.color11 #202020
set_from_resource $col12 i3wm.color12 #202020
set_from_resource $col13 i3wm.color13 #202020
set_from_resource $col14 i3wm.color14 #202020
set_from_resource $col15 i3wm.color15 #202020

set $BOR_WIDTH		2
set $GAP_INNER		10
set $GAP_OUTER		0
set $GAP_NULL		0
set $GAP_TOP		0

set $terminal /usr/local/bin/st

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:Hack Nerd Font 10

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8

# new window default border
new_window pixel 2
new_float pixel 2

# new workspaces
#workspace_layout tabbed

# Autostart applications
exec_always ~/.config/sxhkd/launch.sh
exec_always xrdb .Xresources
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id compton -b -f --config ~/.config/compton.conf
# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
exec --no-startup-id nm-applet
exec --no-startup-id ~/.fehbg
# Start Dropbox
exec --no-startup-id dropbox start -i&
# Start pywal theming
#exec -no-startup-id wal -R
# Nextcloud Client
exec --no-startup-id ~/Downloads/Nextcloud-3.0.1-x86_64.AppImage
# Start Polybar
exec_always --no-startup-id $HOME/.config/polybar/launch.sh

# The combination of xss-lock, nm-applet and pactl is a popular choice, so
# they are included here as an example. Modify as you see fit.

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
# exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock-fancy --nofork
exec --no-startup-id xautolock -time 10 -locker i3lock-fancy

#----------------------------------------
#----- Start Apps in workspaces
#----------------------------------------
exec --no-startup-id i3-msg 'workspace $ws1; exec $terminal'
exec --no-startup-id i3-msg 'workspace $ws4; exec /usr/bin/firefox'


#-----------------------------------------
#----- Special Window
#-----------------------------------------

# starting dropdown terminal
for_window [instance="dropdown"] floating enable
for_window [instance="dropdown"] resize set 625 400
for_window [instance="dropdown"] move scratchpad
for_window [instance="dropdown"] border pixel 5
exec --no-startup-id $terminal -n dropdown
bindsym $mod+b  [instance="dropdown"] scratchpad show; [instance="dropdown"] move position center

# Use pactl to adjust volume in PulseAudio.
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

hide_edge_borders smart

# All Windows float by default
for_window [window_role="popup"] floating enable
for_window [class="^.*"] border pixel $BOR_WIDTH

# Open applications on specific workspaces
# find class with `xprop | awk '/WM_CLASS/ { print $4 }'`
assign [class="Chromium"] $ws4
assign [class="Google-chrome"] $ws4
assign [class="Firefox"] $ws4
assign [class="Mendeley Desktop"] $ws7
assign [class="discord"] $ws8
for_window [class="Spotify"] move to workspace $ws9

#Einstellungen für spezielle Programme
for_window [class="(?i)vlc"] floating enable border normal
for_window [class="(?i)virtualbox"] floating enable border normal
for_window [class="(?i)claws-mail"] floating enable border normal
for_window [class="mplayer"] floating disable border none
for_window [class="(?i)celluloid"] floating enable border none
for_window [class="(?i)doublecmd"] floating enable border normal

bindsym --release Caps_Lock exec pkill -SIGRTMIN+11 i3blocks
bindsym --release Num_Lock  exec pkill -SIGRTMIN+11 i3blocks


